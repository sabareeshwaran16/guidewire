# ── Anthropic Claude API (dynamic premium calculation) ──────────────────────
# Get yours at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_api_key_here

# ── OpenWeatherMap API (real-time rain + temperature + AQI) ─────────────────
# Free tier: 1,000 calls/day — https://openweathermap.org/api
# Sign up at https://home.openweathermap.org/users/sign_up
VITE_OPENWEATHER_API_KEY=your_openweather_api_key

# ── WAQI (World Air Quality Index) token (real-time AQI) ────────────────────
# Free token: https://aqicn.org/data-platform/token/
# Use "demo" for testing (rate-limited)
VITE_WAQI_TOKEN=demo
